{
  "servers": {
    "MS-Learn": {
      "url": "https://learn.microsoft.com/api/mcp",
      "type": "http"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${input:context7-api-key}"
      }
    },
    "adc-sessions": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/AdcSessionMcpStdio.csproj"
      ]
    }
  },
  "inputs": [
    {
      "id": "context7-api-key",
      "type": "promptString",
      "description": "Enter your Context7 API key"
    }
  ]
}
